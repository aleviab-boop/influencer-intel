{
  "manifest_version": 3,
  "name": "Influencer Intel Scraper",
  "version": "0.1.0",
  "description": "Internal extension — extracts public Instagram profile data when driven by Playwright. Not for end-user distribution.",
  "permissions": ["scripting", "storage", "activeTab"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://instagram.com/*",
    "https://www.youtube.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*", "https://instagram.com/*"],
      "js": ["content/ig-helpers.js", "content/ig-extractor.js"],
      "run_at": "document_idle"
    }
  ]
}
