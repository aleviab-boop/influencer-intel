{
  "name": "influencer-intel",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "shared",
    "scraper",
    "platform"
  ],
  "scripts": {
    "scraper:dev": "npm --workspace scraper run dev",
    "scraper:start": "npm --workspace scraper run start",
    "scraper:capture": "npm --workspace scraper run capture-session",
    "platform:dev": "npm --workspace platform run dev",
    "platform:build": "npm --workspace platform run build",
    "platform:start": "npm --workspace platform run start",
    "db:health": "npm --workspace shared run db:health",
    "db:smoke": "npm --workspace shared run db:smoke",
    "db:discover-smoke": "npm --workspace shared run db:discover-smoke",
    "db:rescore-quality": "npm --workspace shared run db:rescore-quality",
    "score-smoke": "npm --workspace shared run score-smoke",
    "db:diff": "npm --workspace shared run db:diff",
    "db:fix": "npm --workspace shared run db:fix",
    "db:check-session": "npm --workspace shared run db:check-session",
    "typecheck": "npm --workspace shared run typecheck && npm --workspace scraper run typecheck && npm --workspace platform run typecheck",
    "relay": "node tools/ig-relay.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
